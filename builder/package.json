{
    "name": "phpulse",
    "version": "1.0.0",
    "description": "PHPulse is a PHP framework for building desktop applications.",
    "main": "main.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "electron .",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux",
        "build:all": "electron-builder -mwl",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.phpulse.app",
        "productName": "PHPulse",
        "asar": false,
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
            "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
            "!**/node_modules/*.d.ts",
            "!**/node_modules/.bin",
            "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
            "!.editorconfig",
            "!**/._*",
            "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
            "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
            "!**/{appveyor.yml,.travis.yml,circle.yml}",
            "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "ia32"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64",
                        "ia32"
                    ]
                }
            ],
            "icon": "assets/build/icon.ico"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "icon": "assets/build/icon.icns",
            "category": "public.app-category.developer-tools"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb",
                "rpm"
            ],
            "icon": "assets/build/icon.png",
            "category": "Development"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ibnsultan/PHPulse.git"
    },
    "keywords": [
        "php",
        "phpulse",
        "electron",
        "desktop",
        "dev",
        "nodejs"
    ],
    "author": "Abdulbasit Rubeya",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/ibnsultan/PHPulse/issues"
    },
    "homepage": "https://github.com/ibnsultan/PHPulse#readme",
    "devDependencies": {
        "electron": "^40.7.0",
        "electron-builder": "^26.8.1"
    }
}
